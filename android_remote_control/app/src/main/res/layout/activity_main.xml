<?xml version="1.0" encoding="utf-8"?>
<!--
    Main activity layout for SnapSolve Remote Control.

    Structure (top → bottom):
      1. Connection bar  — IP field, port field, Connect/Disconnect button
      2. Status row      — small label showing Connected / Disconnected state
      3. Touchpad area   — fills remaining vertical space; handles mouse movement
      4. Action buttons  — 3-column grid mirroring the SnapSolve overlay panel
      5. Instructions    — brief gesture reference text
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_dark">

    <!-- ===== Connection Bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1565C0"
        android:padding="12dp"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server Connection"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/ipAddressEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Server IP (e.g. 192.168.1.100)"
                android:textColor="#000000"
                android:textColorHint="#666666"
                android:textSize="14sp"
                android:inputType="textNoSuggestions"
                android:singleLine="true"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/portEditText"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:hint="Port"
                android:textColor="#000000"
                android:textColorHint="#666666"
                android:textSize="14sp"
                android:inputType="number"
                android:singleLine="true"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Connection Status Row ===== -->
    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/status_disconnected"
        android:textColor="@color/status_disconnected"
        android:textSize="12sp"
        android:padding="4dp"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <!-- ===== Touchpad Area ===== -->
    <com.snapremote.control.TouchpadView
        android:id="@+id/touchpadView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp" />

    <!-- ===== Transcription Language Selector ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_transcription_lang"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/langSpinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false" />
    </LinearLayout>

    <!-- ===== Action Buttons (3-column grid) ===== -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:layout_marginBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/captureButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_capture"
            android:backgroundTint="@color/btn_capture"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reselectButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_reselect"
            android:backgroundTint="@color/btn_reselect"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/multiCaptureButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_multi_select"
            android:backgroundTint="@color/btn_multi_select"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/endMultiButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_end_multi"
            android:backgroundTint="@color/btn_end_multi"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/toggleStitchingButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_toggle_stitching"
            android:backgroundTint="@color/btn_toggle_stitching"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cycleSourceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_cycle_source"
            android:backgroundTint="@color/btn_cycle_source"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/togglePanelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_toggle_panel"
            android:backgroundTint="@color/btn_toggle_panel"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/newChatButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_new_chat"
            android:backgroundTint="@color/btn_new_chat"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_cancel"
            android:backgroundTint="@color/btn_cancel"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/typeTextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="@string/btn_type_text"
            android:backgroundTint="@color/btn_type_text"
            android:textColor="@color/text_primary"
            android:layout_margin="4dp"
            android:enabled="false" />
    </GridLayout>

    <!-- ===== Gesture Instructions ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/touchpad_instructions"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:padding="8dp"
        android:gravity="center" />

</LinearLayout>
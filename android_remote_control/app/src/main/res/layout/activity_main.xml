<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1E1E1E">

    <!-- Connection Settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#2C2C2C"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/ipAddressEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Server IP"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:background="#3C3C3C"
            android:padding="8dp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/portEditText"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:hint="Port"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:background="#3C3C3C"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:inputType="number" />

        <Button
            android:id="@+id/connectButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:background="#4CAF50"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Touchpad Area -->
    <com.snapsolve.remotecontrol.TouchpadView
        android:id="@+id/touchpadView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="4"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/captureButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="📸 Capture"
            android:background="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/reselectButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="🎯 Reselect"
            android:background="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/multiCaptureButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="➕ Multi-select"
            android:background="#9C27B0"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/endMultiButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="✅ End Multi"
            android:background="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/toggleStitchingButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="🧵 Toggle Stitching"
            android:background="#00BCD4"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/cycleSourceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="🔄 Cycle Source"
            android:background="#FF5722"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/togglePanelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="🖥️ Toggle Panel"
            android:background="#607D8B"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/newChatButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="💬 New Chat"
            android:background="#795548"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column_weight="1"
            android:text="❌ Cancel"
            android:background="#F44336"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"
            android:enabled="false" />
    </GridLayout>

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Touchpad: Single tap = Left click | Double tap = Double click | Two-finger tap = Right click | Three-finger tap = Middle click | Long press = Drag"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:padding="8dp"
        android:gravity="center" />

</LinearLayout>